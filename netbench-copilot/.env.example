# OpenAI API Configuration
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional: Use local models
# OPENAI_API_BASE=http://localhost:8000/v1
# OPENAI_MODEL=local-model

# MCP Server Configuration
MCP_SERVER_HOST=localhost
MCP_SERVER_PORT=8765

# Safety Configuration
# Set this token to enable approval for BIOS changes and reboots
# NETBENCH_APPROVAL_TOKEN=your-secret-approval-token

# Database Configuration
DATABASE_PATH=.cache/netbench.db

# Index Configuration
INDEX_PATH=.cache/index
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# Retrieval Configuration
TOP_K=5
SIMILARITY_THRESHOLD=0.7

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# Dataset Configuration
DATASET_TRAIN_SPLIT=0.8
DATASET_VAL_SPLIT=0.1
DATASET_TEST_SPLIT=0.1

# Optional Fine-tuning Configuration
# MODEL_ID=mistralai/Mistral-7B-v0.1
# LORA_R=8
# LORA_ALPHA=16
# LORA_DROPOUT=0.05
# TRAINING_EPOCHS=3
# BATCH_SIZE=4
# LEARNING_RATE=2e-4